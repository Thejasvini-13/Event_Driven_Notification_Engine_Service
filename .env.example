# ============================================================
# Event-Driven Notification Engine — Environment Configuration
# ============================================================

# Node
NODE_ENV=development
PORT=3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=notification_engine
POSTGRES_USER=notif_user
POSTGRES_PASSWORD=notif_secret
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=notification-engine
KAFKA_GROUP_CRITICAL=notification-critical
KAFKA_GROUP_STANDARD=notification-events
KAFKA_TOPIC_CRITICAL=fin-events-critical
KAFKA_TOPIC_STANDARD=fin-events-standard
KAFKA_TOPIC_DLQ=fin-events-dlq

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=notifications
RABBITMQ_QUEUE_SMS=notif.sms
RABBITMQ_QUEUE_EMAIL=notif.email
RABBITMQ_QUEUE_PUSH=notif.push
RABBITMQ_QUEUE_WHATSAPP=notif.whatsapp
RABBITMQ_QUEUE_INAPP=notif.inapp
RABBITMQ_DLQ=notif.dlq

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=30000
CIRCUIT_BREAKER_HALF_OPEN_REQUESTS=2

# Retry / Backoff
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=30000

# Frequency Cap
FREQ_CAP_GLOBAL_DAILY=12
FREQ_CAP_WINDOW_SECONDS=86400

# Quiet Hours (24h, user local time)
QUIET_HOURS_START=21
QUIET_HOURS_END=8

# SMS Provider (MSG91 Sandbox)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_SENDER_ID=NOTIFN
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+15005550006

# Email Provider (Nodemailer / SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@notification-engine.io

# Push (FCM)
FCM_SERVER_KEY=your_fcm_server_key
FCM_PROJECT_ID=your_firebase_project_id

# WhatsApp (Meta Cloud API)
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Metrics
METRICS_PREFIX=notif_engine
